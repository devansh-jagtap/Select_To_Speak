{
  "manifest_version": 3,
  "name": "Select to Speak",
  "version": "1.0",
  "description": "Select text and hear it spoken aloud.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}